<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:c="clr-namespace:Lightspeed.Controls">

	<Design.PreviewWith>
		<Border Padding="20">
			<StackPanel Spacing="20" Width="300">
				<TextBox>Normal</TextBox>
				<TextBox Classes="sabersport">Saber Sport</TextBox>
			</StackPanel>
		</Border>
	</Design.PreviewWith>

	<Style Selector="TextBox">
		<Style Selector="^.medium">
			<Setter Property="FontSize" Value="22"/>
		</Style>
		<Style Selector="^.large">
			<Setter Property="FontSize" Value="32"/>
		</Style>
	</Style>
	
	<Style Selector="TextBox.sabersport">
		<Setter Property="BorderBrush" Value="{StaticResource SaberSportGreen}"/>
		<Style Selector="^:pointerover /template/ c|LightspeedBorder#PART_BorderElement">
			<Setter Property="TopLeftBackground" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="TopLeftBorderBrush" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="BottomRightBackground" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="BottomRightBorderBrush" Value="{StaticResource SaberSportGreen}"/>
		</Style>
		<Style Selector="^:focus /template/ c|LightspeedBorder#PART_BorderElement">
			<Setter Property="Background" Value="#051403"/>
			<Setter Property="TopLeftBackground" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="TopLeftBorderBrush" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="BottomRightBackground" Value="{StaticResource SaberSportGreen}"/>
			<Setter Property="BottomRightBorderBrush" Value="{StaticResource SaberSportGreen}"/>
		</Style>
	</Style>
	
	<Style Selector="TextBox.required">
		<Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}"/>
		<Style Selector="^ /template/ c|LightspeedBorder#PART_BorderElement">
			<Setter Property="TopLeftBorderBrush" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="BottomRightBorderBrush" Value="{StaticResource OrangeBrush}"/>
		</Style>
		<Style Selector="^:pointerover /template/ c|LightspeedBorder#PART_BorderElement">
			<Setter Property="TopLeftBackground" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="TopLeftBorderBrush" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="BottomRightBackground" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="BottomRightBorderBrush" Value="{StaticResource OrangeBrush}"/>
		</Style>
		<Style Selector="^:focus /template/ c|LightspeedBorder#PART_BorderElement">
			<Setter Property="TopLeftBackground" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="TopLeftBorderBrush" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="BottomRightBackground" Value="{StaticResource OrangeBrush}"/>
			<Setter Property="BottomRightBorderBrush" Value="{StaticResource OrangeBrush}"/>
		</Style>
	</Style>
	
</Styles>
