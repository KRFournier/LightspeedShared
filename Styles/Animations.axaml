<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	
	<Design.PreviewWith>
		<Border Padding="20" Width="128" Height="128">
			<!--<Image Classes="nexusbat" Grid.Column="1" Grid.Row="1"
			   Source="{StaticResource di_NexusBat}"/>-->
			<Panel Classes="rotate_left">
				<Button HorizontalAlignment="Center">OK</Button>
			</Panel>
		</Border>
	</Design.PreviewWith>

	<Style Selector="Panel.slide_up">
		<Style.Animations>
			<Animation Duration="0:0:2" Easing="CircularEaseOut">
				<KeyFrame Cue="0%">
					<Setter Property="Opacity" Value="0.0"/>
					<Setter Property="TranslateTransform.Y" Value="250.0"/>
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="Opacity" Value="1.0"/>
					<Setter Property="TranslateTransform.Y" Value="0.0"/>
				</KeyFrame>
			</Animation>
		</Style.Animations>
	</Style>

	<Style Selector="Image.nexusbat">
		<Style.Animations>
			<Animation Duration="0:0:3" Easing="CircularEaseOut">
				<KeyFrame Cue="0%">
					<Setter Property="Opacity" Value="0.0"/>
					<Setter Property="RotateTransform.Angle" Value="-180.0"/>
					<Setter Property="ScaleTransform.ScaleX" Value="3.0"/>
					<Setter Property="ScaleTransform.ScaleY" Value="3.0"/>
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="Opacity" Value="1.0"/>
				</KeyFrame>
			</Animation>
		</Style.Animations>
	</Style>

	<Style Selector="Image.left_title">
		<Style.Animations>
			<Animation Duration="0:0:2" Easing="CircularEaseOut">
				<KeyFrame Cue="0%">
					<Setter Property="Opacity" Value="0.0"/>
					<Setter Property="TranslateTransform.X" Value="-2000.0"/>
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="Opacity" Value="1.0"/>
					<Setter Property="TranslateTransform.X" Value="0.0"/>
				</KeyFrame>
			</Animation>
		</Style.Animations>
	</Style>

	<Style Selector="Image.right_title">
		<Style.Animations>
			<Animation Duration="0:0:2" Easing="CircularEaseOut">
				<KeyFrame Cue="0%">
					<Setter Property="Opacity" Value="0.0"/>
					<Setter Property="TranslateTransform.X" Value="2000.0"/>
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="Opacity" Value="1.0"/>
					<Setter Property="TranslateTransform.X" Value="0.0"/>
				</KeyFrame>
			</Animation>
		</Style.Animations>
	</Style>

	<Style Selector="Image.rotate_left">
		<Style.Animations>
			<Animation IterationCount="INFINITE" Duration="0:0:2">
				<KeyFrame Cue="0%">
					<Setter Property="RotateTransform.Angle" Value="0.0"/>
				</KeyFrame>
				<KeyFrame Cue="100%">
					<Setter Property="RotateTransform.Angle" Value="-360.0"/>
				</KeyFrame>
			</Animation>
		</Style.Animations>
	</Style>
	
</Styles>
